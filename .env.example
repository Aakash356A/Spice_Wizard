# Copy this file to .env and replace placeholders locally.
# Never commit the real .env file.

# Generic OpenAI-compatible backend. Use these for AMD Qwen or another local server.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-with-your-private-key
LLM_MODEL=openai/gpt-5

# Optional OpenRouter compatibility variables used by the legacy GUI planner.
OPENROUTER_API_KEY=replace-with-your-private-key
OPENROUTER_MODEL=openai/gpt-5

# Optional LTspice overrides. Usually not needed on macOS after LTspice install.
# LTSPICE_CMD=/Applications/LTspice.app/Contents/MacOS/LTspice
# LTSPICE_LIB_PATH=/Applications/LTspice.app/Contents/Resources/lib

# Optional local Gemma base-model override.
# Defaults to the base model declared in models/gemma3-lora/adapter_config.json.
# LOCAL_GEMMA_BASE_MODEL=unsloth/gemma-3-1b-it-unsloth-bnb-4bit

# Opt in only after the adapter and compatible base model are prepared.
# SPICE_WIZARD_ENABLE_LOCAL_AGENT=1
